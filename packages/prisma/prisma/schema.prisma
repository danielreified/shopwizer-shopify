generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl", "linux-musl-openssl-3.0.x", "darwin-arm64", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
  output          = "../../../node_modules/.prisma/client"
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, pgcrypto]
  url        = env("DATABASE_URL")
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum ColorSource {
  FUZZY
  CSS
  NONE
  METAFIELD
  FALLBACK
}

// ------------------------------------------------------
// 🧱 GENDER & AGE ENUMS
// ------------------------------------------------------

enum Gender {
  FEMALE
  MALE
  UNISEX
  OTHER
  UNKNOWN
}

enum GenderSource {
  METAFIELD
  AUTO
  NONE
}

enum CategorySource {
  FIELD
  AUTO
  NONE
}

enum AgeBucket {
  NEWBORN
  BABY
  KID
  TEEN
  ADULT
  ALL_AGE
  UNKNOWN
}

enum AgeSource {
  METAFIELD
  AUTO
  NONE
}

// ======================================================================================
// ======================================================================================
// ======================================================================================

model Shop {
  id               String   @id
  domain           String   @unique
  shopifyGid       String?
  name             String?
  email            String?
  countryCode      String?
  currency         String?
  timezone         String? // IANA timezone e.g. "America/New_York"
  primaryDomainUrl String?
  planName         String?
  partnerDev       Boolean?

  scopes   String?
  isActive Boolean @default(true)

  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?

  trialEndsAt DateTime?

  recommenderPreferences Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shopAppPlanCodeRedemption  ShopAppPlanCodeRedemption[]
  subscriptions              ShopSubscription[]
  Product                    Product[]
  ProductEmbedding           ProductEmbedding[]
  ProductFeature             ProductFeature[]
  ProductGraph               ProductGraph[]
  CategoryGraph              CategoryGraph[]
  ComputedBundle             ComputedBundle[]
  BundleSlot                 BundleSlot[]
  RailMetric                 RailMetric[]
  Jobs                       Job[]
  productAttributesEmbedding ProductAttributesEmbedding[]
  orders                     Order[]
  orderLineItems             OrderLineItem[]
  shopIntegrations           ShopIntegration[]
  shopOnboarding             ShopOnboarding?
  shopStatus                 ShopStatus?
  shopSettings               ShopSettings?
  widgetConfig               WidgetConfig?
  customStyles               CustomStyle[]
  exclusionRules             ExclusionRule[]
}

model WidgetConfig {
  id     String @id @default(cuid())
  shopId String @unique
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Design tokens: { primaryColor, borderRadius, fontColor, etc. }
  design Json @default("{}")

  // Rail settings: { similar: { title: "..." }, trending: { title: "..." } }
  rails Json @default("{}")

  updatedAt DateTime @updatedAt
}

// ======================================================================================

enum OnboardingStep {
  PREFERENCE
  SYNC_PRODUCTS
  SYNC_ORDERS
  THEME_INSTALL
  COMPLETED
}

model ShopOnboarding {
  id     String @id @default(cuid())
  shopId String @unique

  step      OnboardingStep @default(PREFERENCE)
  updatedAt DateTime       @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
}

// ======================================================================================

enum IntegrationCategory {
  WISHLIST
  REVIEWS
}

enum IntegrationProvider {
  JUDGE_ME
  OKENDO
  GROWAVE
  STAMPED
  YOTPO
  SWYM
  LOOX
  NONE
}

// ======================================================================================

enum ExclusionType {
  CATEGORY
  TAG
}

enum ExclusionMode {
  GLOBAL_EXCLUSION // Block products from results
  PAGE_SUPPRESSION // Hide widgets on specific pages
}

model ExclusionRule {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  type      ExclusionType
  mode      ExclusionMode
  label     String
  itemValue String // The actual category ID or tag string
  withDesc  Boolean       @default(true) // Include subcategories for categories

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, type, itemValue, mode], name: "shopId_type_itemValue_mode")
  @@index([shopId])
}

// ======================================================================================

model ShopIntegration {
  id     String @id @default(cuid())
  shopId String

  category IntegrationCategory
  provider IntegrationProvider
  enabled  Boolean             @default(false)

  meta      Json?
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, category, provider])
}

// ======================================================================================
// ======================================================================================
// ======================================================================================

enum ProductSyncState {
  IDLE
  RUNNING
  FAILED
  COMPLETED
}

model ShopStatus {
  id     String @id @default(cuid())
  shopId String @unique

  productSyncState   ProductSyncState @default(IDLE)
  productSyncStarted DateTime?
  productSyncEnded   DateTime?
  productBulkOpId    String? // Shopify bulk operation GID we started

  cacheLastCleared DateTime?
  cacheStale       Boolean   @default(false)

  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
}

// ======================================================================================
// ======================================================================================
// ======================================================================================

model ShopSettings {
  id     String @id @default(cuid())
  shopId String @unique

  // Contact person for alerts
  contactName  String?
  contactEmail String?

  // Notification preferences
  productCapAlerts  Boolean @default(true)
  reportEvery2Weeks Boolean @default(false)

  // Recommender on/off toggles: { similar: true, color: true, trending: true, newArrivals: true, bestSellers: true }
  recommenders Json?

  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])
}

model CustomStyle {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  themeId   String // Shopify theme ID (e.g., "123456789") - allows per-theme CSS
  key       String // e.g., 'global', 'product-rail', 'pdp-bundles'
  css       String?  @db.Text
  updatedAt DateTime @updatedAt

  @@unique([shopId, themeId, key])
  @@index([shopId, themeId])
}

// ======================================================================================
// ======================================================================================
// ======================================================================================

model ShopAppPlanCodeRedemption {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  planCodeId String
  planCode   AppPlanCode @relation(fields: [planCodeId], references: [id], onDelete: Cascade)

  redeemedAt DateTime @default(now())

  @@unique([shopId, planCodeId])
  @@index([planCodeId])
}

model AppPlan {
  id       String          @id @default(cuid())
  name     String
  slug     String          @unique
  interval BillingInterval
  currency String
  price    Decimal         @db.Decimal(12, 2)

  // Plan limits
  monthlyOrderLimit Int? // Max orders per month (null = unlimited)

  isCustom          Boolean            @default(true)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  appPlanCodes      AppPlanCode[]
  shopSubscriptions ShopSubscription[]
}

model AppPlanCode {
  id   String @id @default(cuid())
  code String @unique

  title String?

  appPlanId String
  appPlan   AppPlan @relation(fields: [appPlanId], references: [id], onDelete: Cascade)

  validFrom DateTime?
  validTo   DateTime?
  isActive  Boolean   @default(true)

  maxRedemptions Int?
  usageCount     Int  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions ShopAppPlanCodeRedemption[]

  @@index([appPlanId])
}

model ShopSubscription {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id])

  shopifyGid       String    @unique
  name             String?
  status           String
  interval         String?
  price            Decimal   @db.Decimal(12, 2)
  trialDays        Int?
  currentPeriodEnd DateTime?

  // Custom plan linking
  isCustom  Boolean  @default(false)
  appPlanId String?
  appPlan   AppPlan? @relation(fields: [appPlanId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime? @db.Timestamptz(6)
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

// ------------------------------
// Product catalog
// ------------------------------

enum ProductPipelineState {
  PROCESSING
  COMPLETED
  FAILED
}

model Product {
  id     BigInt @id @db.BigInt
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Shopify identifiers
  shopifyGid       String        @unique
  handle           String?
  title            String
  vendor           String?
  vendorNormalized String? // Normalized vendor name (Title Case) for fast JOINs with VendorEmbedding
  status           ProductStatus @default(ACTIVE)
  productType      String?
  tags             String[]      @default([])
  descriptionHtml  String?       @db.Text

  // Whether this product is enabled for recommendations
  enabled Boolean @default(true)

  categoryId     String?
  category       Category?      @relation(fields: [categoryId], references: [id])
  categorySource CategorySource @default(AUTO)

  collectionHandles String[] @default([])

  gender       Gender[]      @default([])
  genderSource GenderSource? @default(NONE)

  ageBucket AgeBucket[] @default([])
  ageSource AgeSource?  @default(NONE)

  images   ProductImage[]
  variants ProductVariant[]

  // ✔ FIXED: these are now proper 1-to-1 relations (no FK lives here)
  embeddings           ProductEmbedding?
  attributesEmbeddings ProductAttributesEmbedding?

  // Vendor embedding relation (via vendorNormalized)
  vendorEmbed VendorEmbedding? @relation(fields: [vendorNormalized], references: [vendorNormalized])

  ProductFeature     ProductFeature?
  ProductGraphSource ProductGraph[]   @relation("GraphSource")
  ProductGraphTarget ProductGraph[]   @relation("GraphTarget")
  ComputedBundles    ComputedBundle[]
  BundleSlots        BundleSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchandisingBasket String?

  pipelineState ProductPipelineState @default(COMPLETED)

  @@index([shopId])
  @@index([shopId, handle])
  @@index([categoryId])
  @@index([vendorNormalized])
}

model ProductVariant {
  id        BigInt  @id @db.BigInt
  productId BigInt  @db.BigInt
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  shopifyGid     String   @unique
  sku            String?
  barcode        String?
  position       Int?
  title          String?
  price          Decimal? @db.Decimal(14, 4)
  priceUsd       Decimal? @db.Decimal(14, 4)
  compareAtPrice Decimal? @db.Decimal(14, 4)

  inventoryQuantity Int?
  inventoryItemGid  String?

  imageId BigInt?       @db.BigInt
  image   ProductImage? @relation(fields: [imageId], references: [id])

  color_label   String?
  color_hex     String?
  lab_l         Float?
  lab_a         Float?
  lab_b         Float?
  hue           Float?
  color_source  ColorSource?
  color_version Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

model ProductImage {
  id        BigInt  @id @db.BigInt
  productId BigInt  @db.BigInt
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  shopifyGid String? @unique
  url        String
  altText    String?
  width      Int?
  height     Int?
  position   Int?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  ProductVariant ProductVariant[]

  @@index([productId])
}

//
// ✔ 1-1 ProductEmbedding
//
model ProductEmbedding {
  id        String  @id @default(cuid())
  productId BigInt  @unique // owns the relation
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  version Int @default(1)

  textHash   String                      @db.Char(64)
  sourceText String?                     @db.Text
  vector     Unsupported("vector(1536)")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

//
// ✔ 1-1 ProductAttributesEmbedding
//
model ProductAttributesEmbedding {
  id        String  @id @default(cuid())
  productId BigInt  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  version Int @default(1)

  categoryCount Int @default(0)
  valueCount    Int @default(0)

  textHash   String                      @db.Char(64)
  sourceText String?                     @db.Text
  vector     Unsupported("vector(1536)")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}

//
// ✔ Global Vendor Embedding (shared across shops)
// One embedding per normalized vendor name, reused by all products with that vendor
//
model VendorEmbedding {
  id String @id @default(cuid())

  // Normalized vendor name (Title Case, trimmed)
  // e.g., "Nike", "Under Armour", "Samsung"
  vendorNormalized String @unique

  // Original vendor name that triggered creation (for debugging)
  vendorOriginal String?

  // Embedding vector
  vector Unsupported("vector(1536)")

  // Back-relation to products
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductGraph {
  id       String @id @default(cuid())
  shopId   String
  sourceId BigInt
  targetId BigInt

  // ---- Relationship metrics ----
  type  String @default("FBT") // "BUNDLE", "FBT", "SIMILAR"
  count Int    @default(0) // Raw number of co-purchases

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  source Product @relation("GraphSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Product @relation("GraphTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([shopId, sourceId, targetId, type])
  @@index([shopId, sourceId, count(sort: Desc)])
  @@index([shopId])
  @@index([sourceId])
  @@index([targetId])
}

// ═══════════════════════════════════════════════════════════════════
// SELF-OPTIMIZING BUNDLE ENGINE
// ═══════════════════════════════════════════════════════════════════

model CategoryGraph {
  id             String @id @default(cuid())
  shopId         String
  sourceCategory String // e.g., "aa-1-1"
  targetCategory String // e.g., "aa-1-5"
  count          Int    @default(0) // Raw number of orders containing this category pair

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, sourceCategory, targetCategory])
  @@index([shopId, sourceCategory])
}

model BundleSlot {
  id        String   @id @default(cuid())
  shopId    String
  productId BigInt
  slotIndex Int
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop    Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  bundles ComputedBundle[]

  @@unique([shopId, productId, slotIndex])
  @@index([shopId, productId])
}

model ComputedBundle {
  id        String  @id @default(cuid())
  shopId    String
  productId BigInt // Origin product
  slotId    String?

  candidateIds Json // [BigInt, BigInt, BigInt] - The 3 recommended product IDs
  variant      String // Legacy label for compatibility (e.g. control/explore or bundle_1/2/3)
  slotIndex    Int     @default(1) // Stable slot identity (1..3)
  enabled      Boolean @default(true) // Merchant toggle; generation still refreshes all slots
  status       String  @default("ACTIVE") // "ACTIVE", "ARCHIVED"
  weight       Float   @default(0.33) // Selection probability for frontend
  pinConfig    Json? // Optional manual pin configuration (e.g., { pinnedIds })

  // Performance Metrics (Updated hourly by service-analytics)
  views24h      Int   @default(0)
  clicks24h     Int   @default(0)
  conversions7d Int   @default(0) // Attributed purchases via slate_id
  revenue7d     Float @default(0) // Revenue from attributed purchases

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop    Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  slot    BundleSlot? @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId, slotIndex])
  @@index([shopId, productId, status])
  @@index([shopId, productId, status, slotIndex])
  @@index([shopId, productId, status, enabled])
  @@index([slotId, status])
  @@index([shopId, status])
}

model Category {
  id               String     @id
  name             String
  rootId           String?
  fullName         String
  pathIds          String[]
  parentId         String?
  parent           Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children         Category[] @relation("CategoryChildren")
  products         Product[]
  depth            Int
  isLeaf           Boolean
  hasAgeGroup      Boolean
  hasTargetGender  Boolean
  hasColor         Boolean
  hasFabric        Boolean
  hasPattern       Boolean
  topLevel         String
  sourceFile       String
  description      String
  attributes       Json?      @default("[]")
  attributesValues Json?      @default("[]")

  vector Unsupported("vector(1536)")?

  @@index([parentId])
  @@index([depth])
}

enum CheckoutStatus {
  PENDING
  COMPLETED
}

model Checkout {
  id                   String         @id
  shopId               String
  completedAt          DateTime?
  abandonedCheckoutUrl String?
  status               CheckoutStatus @default(PENDING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  lineItems CheckoutLineItem[]

  @@index([shopId])
}

model CheckoutLineItem {
  id         String   @id
  checkoutId String
  productId  String?
  variantId  String?
  quantity   Int
  price      Float
  createdAt  DateTime @default(now())

  checkout Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
}

model Order {
  id     BigInt @id @db.BigInt
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  shopifyGid String @unique

  checkoutId    String?
  totalPrice    Decimal? @db.Decimal(14, 4)
  totalPriceUsd Decimal? @db.Decimal(14, 4)

  totalAttributedPrice    Decimal? @db.Decimal(14, 4)
  totalAttributedPriceUsd Decimal? @db.Decimal(14, 4)

  currency String

  processedAt DateTime? // When the order was actually placed by customer

  isBillable Boolean @default(false)
  isBulk     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems OrderLineItem[]

  @@unique([id, shopId])
  @@index([shopId])
}

model OrderLineItem {
  id     BigInt @id @db.BigInt
  shopId String

  shop Shop @relation(fields: [shopId], references: [id])

  shopifyGid String @unique

  orderId BigInt
  order   Order  @relation(fields: [orderId, shopId], references: [id, shopId], onDelete: Cascade)

  productId  BigInt?
  variantId  BigInt?
  categoryId String?

  quantity   Int
  price      Float
  priceUsd   Decimal? @db.Decimal(14, 4)
  attributed Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([shopId, productId])
  @@index([shopId, categoryId])
}

//
// ProductFeature (already correct 1-1 via @@unique)
//
model ProductFeature {
  productId BigInt @id
  shopId    String

  views24h Int @default(0)
  views7d  Int @default(0)
  views30d Int @default(0)

  clicks24h Int @default(0)
  clicks7d  Int @default(0)
  clicks30d Int @default(0)

  carts24h Int @default(0)
  carts7d  Int @default(0)
  carts30d Int @default(0)

  orders7d  Int @default(0)
  orders30d Int @default(0)

  revenue7d  Float @default(0)
  revenue30d Float @default(0)

  bestSellerScore Float?
  trendingScore   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

enum RecommendationRail {
  SIMILAR
  FBT
  TRENDING
  BEST_SELLER
  RECENTLY_VIEWED
  NEW_ARRIVALS
  COLOR_MATCH
  COMPLEMENTARY
}

model RailMetric {
  id     String             @id @default(cuid())
  shopId String
  rail   RecommendationRail
  hour   DateTime // The hour bucket this metric belongs to

  impressions Int @default(0)
  clicks      Int @default(0)

  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, rail, hour])
  @@index([shopId, hour])
  @@index([rail])
}

enum JobStatus {
  IDLE
  RUNNING
  SUCCESS
  FAILED
  PENDING
}

enum JobType {
  BEST_SELLER
  TRENDING
  NEW_ARRIVALS
  BUNDLE_GENERATE
  GRAPH_WEIGHTS_DAILY
}

model Job {
  id               String    @id @default(cuid())
  shopId           String
  shop             Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type             JobType
  enabled          Boolean   @default(true)
  scheduleInterval Int
  lastRun          DateTime?
  nextRun          DateTime?
  status           JobStatus @default(IDLE)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([shopId, type])
}

// ====================================================================
// PxAnalytics
// ====================================================================

model PxAnalytics {
  id String @id @default(cuid())

  shop   String
  event  String
  window DateTime
  count  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, event, window])
  @@index([shop, event])
}

// ====================================================================
// Email Logs
// ====================================================================

enum EmailType {
  INSTALL
  UNINSTALL
  PLAN_CHANGE
  USAGE_80
  USAGE_90
  USAGE_100
  USAGE_APPROACHING
  USAGE_CAPPED
  USAGE_RESET
  SYNC_COMPLETE
}

model EmailLog {
  id       String    @id @default(cuid())
  shopId   String?
  type     EmailType
  to       String
  subject  String
  sentAt   DateTime  @default(now())
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([type])
  @@index([sentAt])
}

// -----------------------------------------------------------
// -----------------------------------------------------------

enum GlobalJobType {
  FEATURE_HOURLY
  FEATURE_VALIDATE_DAILY_24H
  FEATURE_VALIDATE_DAILY_7D
  FEATURE_VALIDATE_DAILY_30D
  FEATURE_BEST_SELLER
  FEATURE_TRENDING
  RAIL_HOURLY
}

model GlobalJobCheckpoint {
  id          String        @id @default(cuid())
  job         GlobalJobType
  windowStart DateTime?
  windowEnd   DateTime?
  lastRunAt   DateTime      @default(now())

  @@unique([job])
}

// -----------------------------------------------------------
// -----------------------------------------------------------
