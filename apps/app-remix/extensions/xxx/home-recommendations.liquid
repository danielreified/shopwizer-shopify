<div
  id="shopwise-home-{{ block.id }}"
  class="sw-home-reco"
  data-placement="home"
  data-heading="{{ block.settings.heading | escape }}"
  data-recommender="{{ block.settings.recommender }}"
  data-products-to-show="{{ block.settings.limit }}"
  data-collection-handle="{{ block.settings.collection_handle }}"
  data-image-ratio="{{ block.settings.image_ratio }}"
  data-grid-columns="{{ block.settings.columns }}"
  data-show-vendor="{{ block.settings.show_vendor }}"
>
 <p>dsadasdsads</p>
</div>

{{ 'pdp.css' | asset_url | stylesheet_tag }}

{% schema %}
{
  "name": "Shopwizer (Home)",
  "target": "section",
  "class": "section",
  "javascript": "homepage.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recommended for you"
    },
    {
      "type": "select",
      "id": "recommender",
      "label": "Recommendation source",
      "default": "new",
      "options": [
        { "value": "sellers", "label": "Best sellers" },
        { "value": "trending", "label": "Trending" },
        { "value": "new", "label": "New arrivals" }
      ]
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "Collection handle (optional)"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "default": 8
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "default": "1/1",
      "options": [
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/5", "label": "Portrait (4:5)" },
        { "value": "3/4", "label": "Portrait (3:4)" },
        { "value": "16/9", "label": "Landscape (16:9)" }
      ]
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Grid columns",
      "min": 2,
      "max": 6,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    }
  ]
}
{% endschema %}
