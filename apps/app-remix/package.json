{
  "name": "app-remix",
  "private": true,
  "packageManager": "pnpm@8.15.6",
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "theme:ext:build": "pnpm --filter @repo/shopwise-reco-theme-ext run build",
    "theme:ext:dev": "pnpm --filter @repo/shopwise-reco-theme-ext run dev",
    "px:ext:build": "pnpm --filter @repo/my-web-pixel run build",
    "px:ext:dev": "pnpm --filter @repo/my-web-pixel run dev",
    "checkout:ext:build": "pnpm --filter @repo/thank-you-recs exec shopify app build --skip-dependencies-installation",
    "ext:build:all": "pnpm run theme:ext:build && pnpm run px:ext:build",
    "docker:build": "ROOT_DIR=$(cd ../.. && pwd) ../../scripts/docker/build.sh",
    "docker:push": "../../scripts/docker/push.sh",
    "docker:deploy": "../../scripts/docker/deploy-ecs.sh",
    "ecs:start": "../../scripts/ecs/service.sh start app-remix",
    "ecs:stop": "../../scripts/ecs/service.sh stop app-remix",
    "ecs:status": "../../scripts/ecs/service.sh status app-remix",
    "ecs:logs": "../../scripts/ecs/service.sh logs app-remix",
    "test": "vitest run"
  },
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.878.0",
    "@aws-sdk/client-s3": "^3.878.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@prisma/client": "^6.18.0",
    "@react-router/dev": "^7.9.3",
    "@react-router/fs-routes": "^7.9.3",
    "@react-router/node": "^7.9.3",
    "@react-router/serve": "^7.9.3",
    "@repo/event-contracts": "*",
    "@repo/logger": "workspace:*",
    "@repo/ui": "*",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/cli": "3.86.1",
    "@shopify/polaris": "^12.0.0",
    "@shopify/polaris-icons": "^9.3.1",
    "@shopify/polaris-viz": "^16.16.0",
    "@shopify/shopify-app-express": "^6.0.1",
    "@shopify/shopify-app-react-router": "^1.0.0",
    "@shopify/shopify-app-session-storage-prisma": "^7.0.0",
    "@uiw/react-codemirror": "^4.25.4",
    "date-fns": "4.1.0",
    "isbot": "^5.1.31",
    "isomorphic-dompurify": "3.0.0-rc.2",
    "lucide-react": "^0.536.0",
    "lz-string": "^1.5.0",
    "prisma": "^6.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "^7.9.3",
    "tailwindcss": "^3",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.1.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@repo/tailwind-config": "*",
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "^1.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "workspaces": {
    "packages": [
      "extensions/*"
    ]
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "author": "daniellourie"
}
