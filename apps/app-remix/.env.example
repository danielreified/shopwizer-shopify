# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,read_checkouts,write_products,read_orders,read_metaobjects,write_pixels,read_customer_events,read_themes
SHOPIFY_BILLING_TEST=true

# AWS EventBridge
