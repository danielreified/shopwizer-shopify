CLOUDFRONT_DISTRIBUTION_ID=

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# Logging (BetterStack)
LOGTAIL_SOURCE_TOKEN=
LOGTAIL_ENDPOINT=

# AI
OPENAI_API_KEY=
CATEGORY_EMBEDDINGS_URL=http://localhost:8003

# App
SERVICE_NAME=app-remix
