{
  "name": "@repo/service-px",
  "packageManager": "pnpm@8.15.6",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "node ../../scripts/esbuild-service.mjs",
    "docker:build": "../../scripts/docker/build.sh",
    "docker:push": "../../scripts/docker/push.sh",
    "docker:deploy": "../../scripts/docker/deploy-ecs.sh",
    "ecs:start": "../../scripts/ecs/service.sh start service-px",
    "ecs:stop": "../../scripts/ecs/service.sh stop service-px",
    "ecs:status": "../../scripts/ecs/service.sh status service-px",
