    "@repo/logger": "workspace:*",
    "dotenv": "^17.2.1",
    "lz-string": "^1.5.0",
    "parquets": "^0.10.10"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "*",
    "eslint": "^8.57.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4"
  }
}
